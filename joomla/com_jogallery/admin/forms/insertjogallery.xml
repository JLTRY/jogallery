<?xml version="1.0" encoding="utf-8"?>
<form id="insertjogallery" class="form-validate timepair">
	<fieldset addfieldprefix="JLTRY\Component\JOGallery\Administrator\Field"
			  name="folders">
		<field  name="folders"
				type="mediafolderlist"
				hide_default="true"
				recursive="true"
				label="COM_MEDIA_FOLDERS"
				exclude="thumbs"
				multiple="false"
		/>
	</fieldset>
	<fieldset addfieldprefix="JLTRY\Lib\Field"
			  name="details">
		<field name="select" type="radio" default="0"
           label="COM_MEDIA_SELECT_ALL"
           >
		  <option value="0">All</option>
		  <option value="1">Select</option>
		  <option value="2">Date</option>
		</field>
		<field name="insert" type="text" id="insert" size="50" showon="select:1" />
		<field name="startdate"  type="datetime" default="NOW"
			label="COM_JOGALLERY_START_DATE_LABEL"
			timepair="timepair"
			validate="datepair"
			enddate="enddate"
			size="15"
			showtime="false"
			format="%Y-%m-%d"
			translateformat="false"
			description="COM_JOGALLERY_START_DATE_DESC" class="date start inputbox validate-startdate input-small"
			timeclass="time start validate-starttime input-small" required="true" 
			showon="select:2"/>
		<field name="enddate" type="datetime" default="+1 hour"
			timepair="timepair" label="COM_JOGALLERY_END_DATE_LABEL"
			size="15"
			showtime="false"
			format="%Y-%m-%d"
			translateformat="false"
			description="COM_JOGALLERY_END_DATE_DESC" class="date end inputbox validate-enddate input-small"
			timeclass="time end validate-endtime input-small" required="true" 
			showon="select:2"/>
	</fieldset>
</form>
